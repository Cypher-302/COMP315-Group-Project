# - Project Specific -
# Code::Blocks user/auto-generated files
*.layout
*.depend

# Visual Studio debug symbols
*.pdb

# Directories to ignore
.vscode/
obj/

# - Standard C++ Ignore Rules -
# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
